# Normalize line endings to LF in the repo. Git will convert to CRLF on checkout
# on Windows only where appropriate. This silences the LF-to-CRLF warnings.

* text=auto eol=lf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.zip binary
*.woff binary
*.woff2 binary
*.mo binary

# Text files that should always be LF regardless of host OS
*.php text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.sh text eol=lf

# Windows-only scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
