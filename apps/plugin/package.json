{
  "name": "@churnstop/plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "wp-scripts build --webpack-copy-php assets/admin/src/index.tsx --output-path=assets/admin/build && wp-scripts build --webpack-copy-php assets/modal/src/modal.tsx --output-path=assets/modal/build",
    "dev": "wp-scripts start assets/admin/src/index.tsx --output-path=assets/admin/build",
    "lint": "wp-scripts lint-js assets/",
    "composer-install": "composer install",
    "test": "composer run test",
    "phpcs": "composer run lint",
    "phpstan": "composer run analyse"
  },
  "devDependencies": {
    "@wordpress/components": "^28.0.0",
    "@wordpress/element": "^6.0.0",
    "@wordpress/i18n": "^5.0.0",
    "@wordpress/scripts": "^30.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0"
  }
}
