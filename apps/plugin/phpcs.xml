<?xml version="1.0"?>
<ruleset name="ChurnStop">
    <description>PHP_CodeSniffer ruleset for ChurnStop.</description>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!--
        Warnings are advisory. The plugin treats only ERROR-level findings as
        blocking. Common WPCS warnings (NonceVerification.Recommended,
        WP.Capabilities.Unknown for WooCommerce capabilities, etc.) are noise
        for our context.
    -->
    <arg name="warning-severity" value="0"/>

    <file>src/</file>
    <file>churnstop.php</file>
    <file>uninstall.php</file>

    <rule ref="WordPress-Core">
        <!--
            ChurnStop uses modern PSR-4 + Composer autoloading with namespaced
            classes. The following sniffs enforce older WordPress core file and
            naming conventions (snake_case methods, lowercase-hyphen filenames,
            Yoda conditions, no short ternaries) that contradict that choice.
            They are excluded by design, not by accident. See
            docs/ADR-001-phased-universal-expansion.md for context on why the
            scaffold uses an OOP style.
        -->
        <exclude name="WordPress.Files.FileName"/>
        <exclude name="WordPress.NamingConventions.ValidFunctionName"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName"/>
        <exclude name="WordPress.PHP.YodaConditions"/>
        <exclude name="Universal.Operators.DisallowShortTernary"/>
        <exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>
        <exclude name="Squiz.PHP.DisallowMultipleAssignments"/>
    </rule>
    <rule ref="WordPress-Extra">
        <exclude name="WordPress.Files.FileName"/>
        <exclude name="WordPress.NamingConventions.ValidFunctionName"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName"/>
        <exclude name="WordPress.PHP.YodaConditions"/>
        <exclude name="Universal.Operators.DisallowShortTernary"/>
        <exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>
        <exclude name="Squiz.PHP.DisallowMultipleAssignments"/>
    </rule>
    <rule ref="PHPCompatibilityWP"/>

    <config name="minimum_supported_wp_version" value="6.0"/>
    <config name="testVersion" value="7.4-"/>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="churnstop"/>
            </property>
        </properties>
    </rule>
</ruleset>
