{
  "name": "churnstop/plugin",
  "description": "ChurnStop - Cancellation Save Flow for WooCommerce Subscriptions",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "10up/wp_mock": "^1.1",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpstan/phpstan": "^1.12",
    "szepeviktor/phpstan-wordpress": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "ChurnStop\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ChurnStop\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs --standard=phpcs.xml src/",
    "lint:fix": "phpcbf --standard=phpcs.xml src/",
    "analyse": "phpstan analyse --configuration=phpstan.neon"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
