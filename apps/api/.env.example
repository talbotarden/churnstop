# API server
PORT=8787
DATABASE_URL=postgresql://user:pass@localhost:5432/churnstop
MARKETING_SITE_URL=https://churnstop.org

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs - create these in the Stripe dashboard and paste the
# price_* values here. Monthly is required; yearly is optional (the
# checkout route returns 503 for a cadence if the env var is unset).
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_YEARLY=

# Observability + email
POSTMARK_API_TOKEN=
SENTRY_DSN=
